generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  OWNER
  OWNER_STAFF
  STAFF
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_STAY
  COMPLETED
  CANCELLED
}

enum ServiceOrderStatus {
  PREPARING
  SERVED
}

enum PaymentStatus {
  INITIATED
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

enum ViolationReportStatus {
  OPEN
  RESOLVED
}

model UserProfile {
  id        String   @id @default(uuid())
  authId    String?  @unique @db.Uuid
  name      String
  email     String   @unique
  phone     String?
  role      UserRole @default(CUSTOMER)
  banned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homestays        Homestay[]             @relation("OwnerHomestays")
  bookings         Booking[]              @relation("CustomerBookings")
  articles         Article[]
  reviews          Review[]
  audits           AuditLog[]
  reportsMade      ViolationReport[]      @relation("Reporter")
  reportsReceived  ViolationReport[]      @relation("ReportedUser")
  staffAssignments OwnerStaffAssignment[]
  proxyBookings    Booking[]              @relation("ProxyBookings")

  @@index([role])
  @@map("user_profiles")
}

model Homestay {
  id          String   @id @default(uuid())
  ownerId     String
  name        String
  type        String
  location    String
  description String
  priceFrom   Int
  capacity    Int
  rating      Float    @default(0)
  imageUrl    String
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner            UserProfile            @relation("OwnerHomestays", fields: [ownerId], references: [id])
  rooms            Room[]
  amenities        Amenity[]
  services         Service[]
  bookings         Booking[]
  reviews          Review[]
  images           HomestayImage[]
  staffAssignments OwnerStaffAssignment[]

  @@index([ownerId])
  @@index([type, priceFrom, capacity])
  @@map("homestays")
}

model Room {
  id            String   @id @default(uuid())
  homestayId    String
  name          String
  roomType      String
  pricePerNight Int
  capacity      Int
  totalUnits    Int      @default(1)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  homestay Homestay   @relation(fields: [homestayId], references: [id], onDelete: Cascade)
  bookings Booking[]
  rates    RoomRate[]

  @@index([homestayId])
  @@map("rooms")
}

model RoomRate {
  id            String   @id @default(uuid()) @db.Uuid
  roomId        String
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  pricePerNight Int
  createdAt     DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, startDate, endDate])
  @@map("room_rates")
}

model HomestayImage {
  id         String   @id @default(uuid()) @db.Uuid
  homestayId String
  url        String
  alt        String   @default("")
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  homestay Homestay @relation(fields: [homestayId], references: [id], onDelete: Cascade)

  @@index([homestayId, position])
  @@map("homestay_images")
}

model OwnerStaffAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  homestayId String
  staffId    String
  createdAt  DateTime @default(now())

  homestay Homestay    @relation(fields: [homestayId], references: [id], onDelete: Cascade)
  staff    UserProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([homestayId, staffId])
  @@index([staffId])
  @@map("owner_staff_assignments")
}

model Amenity {
  id         String @id @default(uuid()) @db.Uuid
  homestayId String
  name       String

  homestay Homestay @relation(fields: [homestayId], references: [id], onDelete: Cascade)

  @@unique([homestayId, name])
  @@map("amenities")
}

model Service {
  id          String   @id @default(uuid())
  homestayId  String
  name        String
  description String?
  unitPrice   Int
  included    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  homestay        Homestay         @relation(fields: [homestayId], references: [id], onDelete: Cascade)
  bookingServices BookingService[]

  @@index([homestayId])
  @@map("services")
}

model Booking {
  id             String        @id @default(uuid())
  customerId     String
  homestayId     String
  roomId         String
  guestName      String
  guestPhone     String
  guestCount     Int
  checkIn        DateTime      @db.Date
  checkOut       DateTime      @db.Date
  status         BookingStatus @default(PENDING)
  roomTotal      Int
  serviceTotal   Int           @default(0)
  taxTotal       Int           @default(0)
  grandTotal     Int
  proxyCreatedBy String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer   UserProfile      @relation("CustomerBookings", fields: [customerId], references: [id])
  homestay   Homestay         @relation(fields: [homestayId], references: [id])
  room       Room             @relation(fields: [roomId], references: [id])
  services   BookingService[]
  payment    Payment?
  proxyActor UserProfile?     @relation("ProxyBookings", fields: [proxyCreatedBy], references: [id])

  @@index([customerId])
  @@index([homestayId, status])
  @@index([roomId])
  @@index([proxyCreatedBy], map: "bookings_proxy_created_by_idx")
  @@index([checkIn, checkOut])
  @@map("bookings")
}

model BookingService {
  id        String             @id @default(uuid())
  bookingId String
  serviceId String
  name      String
  quantity  Int
  unitPrice Int
  total     Int
  status    ServiceOrderStatus @default(PREPARING)
  createdAt DateTime           @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@index([bookingId])
  @@index([serviceId])
  @@map("booking_services")
}

model Payment {
  id          String        @id @default(uuid())
  bookingId   String        @unique
  provider    String
  providerRef String?
  status      PaymentStatus @default(INITIATED)
  amount      Int
  checkoutUrl String?
  rawPayload  Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("payments")
}

model Article {
  id        String        @id @default(uuid())
  authorId  String
  title     String
  slug      String        @unique
  excerpt   String
  content   String
  status    ArticleStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  author UserProfile @relation(fields: [authorId], references: [id])

  @@index([status])
  @@index([authorId])
  @@map("articles")
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  homestayId String
  rating     Int
  comment    String
  createdAt  DateTime @default(now())

  user     UserProfile @relation(fields: [userId], references: [id])
  homestay Homestay    @relation(fields: [homestayId], references: [id], onDelete: Cascade)

  @@index([homestayId])
  @@index([userId])
  @@map("reviews")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  actor UserProfile? @relation(fields: [actorId], references: [id])

  @@index([entity, entityId])
  @@index([actorId])
  @@map("audit_logs")
}

model ViolationReport {
  id             String                @id @default(uuid())
  reporterId     String
  reportedUserId String
  reason         String
  status         ViolationReportStatus @default(OPEN)
  createdAt      DateTime              @default(now())

  reporter     UserProfile @relation("Reporter", fields: [reporterId], references: [id])
  reportedUser UserProfile @relation("ReportedUser", fields: [reportedUserId], references: [id])

  @@index([status])
  @@index([reporterId])
  @@index([reportedUserId])
  @@map("violation_reports")
}
