# Backend on Render
PORT="4000"
WEB_ORIGIN="https://homestaytayninh-frontend.vercel.app"

# Redis primary persistence and sessions
REDIS_URL=redis://red-d8anu9ul51nc73e2o7a0:6379
SESSION_TTL_SECONDS=604800
REDIS_AUTO_SEED=true
# Legacy flag kept for old deploy dashboards. Seed is controlled by REDIS_AUTO_SEED.
REDIS_SEED_DEMO=true

# Google OAuth
GOOGLE_CLIENT_ID=""

# CloudAMQP RabbitMQ
RABBITMQ_URL="amqps://[USER]:[PASSWORD]@[HOST]/[VHOST]"

# Payment
PAYMENT_PROVIDER="apipay"
APIPAY_BASE_URL="https://app.apipay.vn"
APIPAY_CREATE_PAYMENT_PATH="/v1/client/payment-requests"
APIPAY_BANK_PUBLIC_ID=""
APIPAY_ACCESS_KEY=""
APIPAY_SECRET_KEY=""
APIPAY_RETURN_URL="https://homestaytayninh-frontend.vercel.app/payment/result"
APIPAY_CALLBACK_URL="https://homestaytayninh-backend.onrender.com/api/payments/apipay/webhook"
APIPAY_WEBHOOK_CREATE_PATH="/v1/client/webhooks"
APIPAY_WEBHOOK_TYPE="IN"
