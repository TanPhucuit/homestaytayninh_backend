# Backend on Render
PORT="4000"
WEB_ORIGIN="https://your-frontend.vercel.app,http://localhost:3000"
AUTH_MODE="supabase"

# Supabase PostgreSQL
SUPABASE_URL="https://qvzzykkpekmydtbijhqr.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key_here"
# Optional for future backend Data API administration; Prisma writes use DATABASE_URL.
# Never expose this value in the Next.js frontend.
SUPABASE_SECRET_KEY=""
DATABASE_URL="postgresql://postgres.qvzzykkpekmydtbijhqr:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?connection_limit=5&pool_timeout=30"
DIRECT_URL="postgresql://postgres.qvzzykkpekmydtbijhqr:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"
SUPABASE_JWT_SECRET=""

# Upstash Redis
REDIS_URL="rediss://default:[PASSWORD]@[HOST]:[PORT]"

# CloudAMQP RabbitMQ
RABBITMQ_URL="amqps://[USER]:[PASSWORD]@[HOST]/[VHOST]"

# Payment
PAYMENT_PROVIDER="mock-apipay"
APIPAY_BASE_URL=""
APIPAY_CLIENT_ID=""
APIPAY_SECRET=""
