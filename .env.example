# Backend on Render
PORT="4000"
WEB_ORIGIN="https://your-frontend.vercel.app,http://localhost:3000"
AUTH_MODE="supabase"

# Supabase PostgreSQL
SUPABASE_URL="https://qvzzykkpekmydtbijhqr.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key_here"
# Optional for future backend Data API administration; Prisma writes use DATABASE_URL.
# Never expose this value in the Next.js frontend.
SUPABASE_SECRET_KEY=""
DATABASE_URL="postgresql://postgres.qvzzykkpekmydtbijhqr:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?connection_limit=5&pool_timeout=30"
DIRECT_URL="postgresql://postgres.qvzzykkpekmydtbijhqr:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"
SUPABASE_JWT_SECRET=""

# Redis
REDIS_URL=redis://red-d8anu9ul51nc73e2o7a0:6379

# CloudAMQP RabbitMQ
RABBITMQ_URL="amqps://[USER]:[PASSWORD]@[HOST]/[VHOST]"

# Payment
PAYMENT_PROVIDER="mock-apipay"
APIPAY_BASE_URL=""
APIPAY_CREATE_PAYMENT_PATH="/payments"
APIPAY_ACCESS_KEY=""
APIPAY_SECRET_KEY=""
APIPAY_CURRENCY="VND"
APIPAY_RETURN_URL="https://your-frontend.vercel.app/payment/result"
APIPAY_CALLBACK_URL="https://your-backend.onrender.com/api/payments/callback"
