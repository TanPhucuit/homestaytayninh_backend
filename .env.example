# Backend on Render
PORT="4000"
WEB_ORIGIN="https://homestaytayninh-frontend.vercel.app,http://localhost:3000"

# Redis primary persistence and sessions
REDIS_URL=redis://red-d8anu9ul51nc73e2o7a0:6379
SESSION_TTL_SECONDS=604800
REDIS_AUTO_SEED=true
# Legacy flag kept for old deploy dashboards. Seed is controlled by REDIS_AUTO_SEED.
REDIS_SEED_DEMO=true

# Google OAuth
GOOGLE_CLIENT_ID=""

# CloudAMQP RabbitMQ
RABBITMQ_URL="amqps://[USER]:[PASSWORD]@[HOST]/[VHOST]"

# Payment
PAYMENT_PROVIDER="mock-apipay"
APIPAY_BASE_URL=""
APIPAY_CREATE_PAYMENT_PATH="/payments"
APIPAY_ACCESS_KEY=""
APIPAY_SECRET_KEY=""
APIPAY_CURRENCY="VND"
APIPAY_RETURN_URL="https://your-frontend.vercel.app/payment/result"
APIPAY_CALLBACK_URL="https://your-backend.onrender.com/api/payments/callback"
